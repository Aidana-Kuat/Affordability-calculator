{"title":"Explore your budget","markdown":{"yaml":{"title":"Explore your budget"},"headingText":"Enter Your Information","containsRefs":false,"markdown":"\n\n<div style=\"max-width:500px\">\n\nSalary per year ($)\n\n<input id=\"salary\" type=\"number\" placeholder=\"60000\">\n\nCity\n\n<select id=\"city\">\n<option value=\"1400\">Pittsburgh, PA</option>\n<option value=\"2100\">Chicago, IL</option>\n<option value=\"3200\">New York, NY</option>\n<option value=\"1600\">Dallas, TX</option>\n\n\n</select>\n\nMonthly student loan ($)\n\n<input id=\"loans\" type=\"number\" placeholder=\"300\">\n\nOther monthly spending ($)\n\n<input id=\"spending\" type=\"number\" placeholder=\"800\">\n\n<br><br>\n\n<button onclick=\"calculate()\">Calculate</button>\n\n</div>\n\n\n## Results\n\n<div id=\"results\"></div>\n\n<script>\n\nfunction calculate() {\n\nlet salary = document.getElementById(\"salary\").value\nlet rent = document.getElementById(\"city\").value\nlet loans = document.getElementById(\"loans\").value\nlet spending = document.getElementById(\"spending\").value\n\nsalary = Number(salary)\nrent = Number(rent) //Every city has its own rent prices\nloans = Number(loans)\nspending = Number(spending)\n\nlet monthlyIncome = salary * 0.75 / 12 //75% of your salary after taxes\nlet expenses = rent + loans + spending\nlet remaining = monthlyIncome - expenses\n\nlet status = \"\"\n\nif (remaining > 1000) {\nstatus = \"Comfortable\"\n}\nelse if (remaining > 300) {\nstatus = \"Manageable\"\n}\nelse if (remaining > 0) {\nstatus = \"Tight Budget\"\n}\nelse {\nstatus = \"Not Affordable\"\n}\n\ndocument.getElementById(\"results\").innerHTML = `\n<h3>Monthly Income After Tax: $${monthlyIncome.toFixed(0)}</h3>\n<h3>Total Expenses: $${expenses}</h3>\n<h2>Money Left: $${remaining.toFixed(0)}</h2>\n<h2>Status: ${status}</h2>\n`\n}\n</script>\n","srcMarkdownNoYaml":"\n### Enter Your Information\n\n<div style=\"max-width:500px\">\n\nSalary per year ($)\n\n<input id=\"salary\" type=\"number\" placeholder=\"60000\">\n\nCity\n\n<select id=\"city\">\n<option value=\"1400\">Pittsburgh, PA</option>\n<option value=\"2100\">Chicago, IL</option>\n<option value=\"3200\">New York, NY</option>\n<option value=\"1600\">Dallas, TX</option>\n\n\n</select>\n\nMonthly student loan ($)\n\n<input id=\"loans\" type=\"number\" placeholder=\"300\">\n\nOther monthly spending ($)\n\n<input id=\"spending\" type=\"number\" placeholder=\"800\">\n\n<br><br>\n\n<button onclick=\"calculate()\">Calculate</button>\n\n</div>\n\n\n## Results\n\n<div id=\"results\"></div>\n\n<script>\n\nfunction calculate() {\n\nlet salary = document.getElementById(\"salary\").value\nlet rent = document.getElementById(\"city\").value\nlet loans = document.getElementById(\"loans\").value\nlet spending = document.getElementById(\"spending\").value\n\nsalary = Number(salary)\nrent = Number(rent) //Every city has its own rent prices\nloans = Number(loans)\nspending = Number(spending)\n\nlet monthlyIncome = salary * 0.75 / 12 //75% of your salary after taxes\nlet expenses = rent + loans + spending\nlet remaining = monthlyIncome - expenses\n\nlet status = \"\"\n\nif (remaining > 1000) {\nstatus = \"Comfortable\"\n}\nelse if (remaining > 300) {\nstatus = \"Manageable\"\n}\nelse if (remaining > 0) {\nstatus = \"Tight Budget\"\n}\nelse {\nstatus = \"Not Affordable\"\n}\n\ndocument.getElementById(\"results\").innerHTML = `\n<h3>Monthly Income After Tax: $${monthlyIncome.toFixed(0)}</h3>\n<h3>Total Expenses: $${expenses}</h3>\n<h2>Money Left: $${remaining.toFixed(0)}</h2>\n<h2>Status: ${status}</h2>\n`\n}\n</script>\n"},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":false,"echo":true,"output":true,"warning":true,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"daemon-restart":false,